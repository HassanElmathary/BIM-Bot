{
  "name": "revit-mcp-server",
  "version": "2.0.1",
  "description": "MCP Server for Autodesk Revit — 179 AI-powered tools for BIM automation. Works with Claude Desktop, Cursor, Windsurf, and any MCP client. Supports Revit 2020–2026.",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "revit-mcp-server": "./build/index.js",
    "revit-mcp": "./build/index.js"
  },
  "scripts": {
    "clean": "rimraf build",
    "prebuild": "npm run clean",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HassanElmathary/Revit-MCP.git"
  },
  "homepage": "https://github.com/HassanElmathary/Revit-MCP#readme",
  "bugs": {
    "url": "https://github.com/HassanElmathary/Revit-MCP/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "revit",
    "mcp",
    "model-context-protocol",
    "gemini",
    "bim",
    "automation",
    "autodesk",
    "architecture",
    "claude",
    "ai"
  ],
  "author": "Hassan Ahmed Elmathary <hassan.elmathary@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@notionhq/client": "^5.11.0",
    "better-sqlite3": "^12.6.2",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "open": "^10.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "rimraf": "^5.0.10",
    "typescript": "^5.8.2"
  }
}
